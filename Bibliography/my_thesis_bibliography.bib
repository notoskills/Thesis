@article{joshimahajan2025,
  title = {Secure and Interoperable {{EHR}} Management via Hyperledger Fabric: {{The Mrblock}} Framework},
  shorttitle = {Secure and Interoperable {{EHR}} Management via Hyperledger Fabric},
  author = {Joshi, Pranalini and Mahajan, Pratibha},
  date = {2025-03-27},
  journaltitle = {Peer-to-Peer Networking and Applications},
  shortjournal = {Peer-to-Peer Netw. Appl.},
  volume = {18},
  number = {3},
  pages = {133},
  issn = {1936-6450},
  doi = {10.1007/s12083-025-01954-5},
  url = {https://doi.org/10.1007/s12083-025-01954-5},
  urldate = {2026-06-30},
  abstract = {Electronic Health Records (EHRs) require secure and efficient sharing mechanisms to protect patient privacy while ensuring interoperability across healthcare institutions. Traditional systems face challenges related to security, privacy, and access control, leading to risks of data breaches and inefficiencies. Existing blockchain-based EHR solutions, particularly those using PBFT consensus, suffer from high transaction latency and scalability limitations. This paper presents MrBlock, a blockchain-based framework built on Hyperledger Fabric that enhances EHR security, privacy, and interoperability. MrBlock integrates role-based and attribute-based access control with smart contracts for automated and secure access management while leveraging the Raft consensus mechanism for improved performance. Performance evaluations demonstrate that MrBlock achieves up to 2.7\,×\,lower average latency (1.89~s vs. 5.07~s) and higher throughput (8.9 TPS vs. 5.5 TPS) compared to PBFT-based approaches, making it a more efficient solution for secure EHR sharing. By leveraging blockchain’s decentralized architecture, MrBlock mitigates privacy risks and strengthens trust in healthcare data exchange.},
  langid = {english},
  keywords = {Attribute-based access control,Blockchain,Chaincode,Distributed network,Electronic health record,Hyperledger fabric network,Ledger,Role based},
  file = {/Users/noto2k/Zotero/storage/ZWN3MAHT/Joshi and Mahajan - 2025 - Secure and interoperable EHR management via hyperledger fabric The Mrblock framework.pdf}
}

@inproceedings{mamoru2026,
  title = {A {{Blockchain-Based Patient-Centric Access Control Framework}} for {{Electronic Health Record Management}} with {{Revocation Mechanism}}},
  booktitle = {2026 {{IEEE International Research Conference}} on {{Smart Computing}} and {{Systems Engineering}} ({{SCSE}})},
  author = {Mamoru, Sachin and Sawandi, Harini and Ganegoda, Upeksha},
  date = {2026-03},
  volume = {9},
  pages = {1--8},
  issn = {2997-7363},
  doi = {10.1109/SCSE70081.2026.11499774},
  url = {https://ieeexplore.ieee.org/document/11499774},
  urldate = {2026-06-22},
  abstract = {Past global outbreaks of infectious diseases highlighted the essential requirement for an effective health data management system capable of swiftly adapting to and alleviating public health emergencies. The rapid digitization of healthcare systems has increased reliance on Electronic Health Record (EHR) platforms to support clinical decision-making and data sharing. Despite these advances, major health organizations lack a unified EHR system. In most existing systems, patients have limited visibility and control over how their medical data are accessed and shared after initial consent is granted. Modern regulatory frameworks, such as the GDPR and HIPAA, require explicit patient consent before data is collected or processed. Centralized EHR systems often lack patient control, interoperability, and trust. Moreover, access control, a critical security requirement in healthcare information systems, has not been sufficiently addressed. As a result, consent withdrawal is often treated as an administrative or policy-level action rather than a technically enforceable access decision. This limitation contradicts contemporary data protection regulations. Therefore, this paper proposes a patient-centric framework that combines a permissioned blockchain and off-chain storage with a Revocable Access Control Mechanism (RACM) derived from identified gaps in existing blockchain-based access control systems. The framework is evaluated using a publicly available open-access healthcare dataset. Experimental results demonstrate near-linear scalability for record registration, negligible latency for real-time consent and revocation operations, and a 76.713\% reduction in on-chain storage compared to raw EHR storage. These findings indicate that blockchain-based patient-centric consent enforcement is feasible and suitable for healthcare data governance.},
  eventtitle = {2026 {{IEEE International Research Conference}} on {{Smart Computing}} and {{Systems Engineering}} ({{SCSE}})},
  keywords = {Access Control,Architecture,Blockchain},
  file = {/Users/noto2k/Zotero/storage/2RU8YUIR/Mamoru et al. - 2026 - A Blockchain-Based Patient-Centric Access Control Framework for Electronic Health Record Management.pdf}
}

